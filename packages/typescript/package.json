{
  "name": "@scalix-world/sdk",
  "version": "2.0.0",
  "description": "Scalix SDK — unified client for the Scalix platform. OpenAI-compatible chat completions + native platform services (research, RAG, database, docgen, audio, images, text, storage).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "test": "vitest --passWithNoTests",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "llm",
    "sdk",
    "scalix",
    "chat",
    "tts",
    "rag",
    "typescript"
  ],
  "author": "Scalix World <sdk@scalix.world>",
  "license": "MIT",
  "homepage": "https://scalix.world",
  "repository": {
    "type": "git",
    "url": "https://github.com/scalixworld/scalix-sdk"
  },
  "bugs": {
    "url": "https://github.com/scalixworld/scalix-sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "openai": ">=4.50.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openai": "^4.91.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0"
  }
}
